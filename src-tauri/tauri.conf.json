{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Modus",
  "mainBinaryName": "Modus",
  "version": "1.0.8",
  "identifier": "com.leon4z.modus",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Modus",
        "width": 1024,
        "height": 768,
        "minWidth": 980,
        "minHeight": 600,
        "maxWidth": 1440,
        "maxHeight": 1080,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 20,
          "y": 28
        },
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZDMzc0QjQzMkU4RjFFRDgKUldUWUhvOHVRMHMzYkxLOTgrZ3diQTg4NE1Cd3F0SlF3bldWWDROdTBoOUZwKzNLVHptVzVnR0wK",
      "endpoints": [
        "https://github.com/leon4z/Modus/releases/latest/download/latest.json"
      ]
    }
  }
}
